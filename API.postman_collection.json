      "item": [
        {
          "name": "New Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "",
                  "// ===== EXPECTED VALUES =====",
                  "const exp_status_code = 200;",
                  "const exp_max_response_time = 2000;",
                  "const exp_page = 1;",
                  "const exp_per_page = 6;",
                  "const exp_total = 12;",
                  "const exp_total_pages = 2;",
                  "const exp_data_id_array = [1, 2, 3, 4, 5, 6];",
                  "const exp_data_name_array = [\"cerulean\", \"fuchsia rose\", \"true red\", \"aqua sky\", \"tigerlily\", \"blue turquoise\"];",
                  "const exp_data_year_array = [2000, 2001, 2002, 2003, 2004, 2005];",
                  "const exp_data_color_array = [\"#98B2D1\", \"#C74375\", \"#BF1932\", \"#7BC4C4\", \"#E2583E\", \"#53B0AE\"];",
                  "const exp_data_pantone_value_array = [\"15-4020\", \"17-2031\", \"19-1664\", \"14-4811\", \"17-1456\", \"15-5217\"];",
                  "",
                  "// ===== SECTION 1: STATUS CODE =====",
                  "pm.test(\"Validate response status code is \" + exp_status_code, function () {",
                  "    pm.response.to.have.status(exp_status_code);",
                  "});",
                  "",
                  "// ===== SECTION 2: RESPONSE TIME =====",
                  "pm.test(\"Validate response time is below \" + exp_max_response_time + \"ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(exp_max_response_time);",
                  "});",
                  "",
                  "// ===== SECTION 3: RESPONSE BODY STRUCTURE =====",
                  "var jsonData = pm.response.json();",
                  "var dataArray = jsonData.data;",
                  "",
                  "pm.test(\"Validate response body has key: page\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"page\");",
                  "});",
                  "",
                  "pm.test(\"Validate response body has key: per_page\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"per_page\");",
                  "});",
                  "",
                  "pm.test(\"Validate response body has key: total\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"total\");",
                  "});",
                  "",
                  "pm.test(\"Validate response body has key: total_pages\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"total_pages\");",
                  "});",
                  "",
                  "pm.test(\"Validate response body has key: data\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"data\");",
                  "});",
                  "",
                  "pm.test(\"Validate that data is an array\", function () {",
                  "    pm.expect(dataArray).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"Validate that data array has 6 items\", function () {",
                  "    pm.expect(dataArray).to.have.lengthOf(exp_per_page);",
                  "});",
                  "",
                  "// ===== SECTION 4: RESPONSE BODY PARAMETERS =====",
                  "",
                  "// Top-level fields",
                  "pm.test(\"Validate response body param : page\", function () {",
                  "    pm.expect(jsonData.page).to.eql(exp_page);",
                  "});",
                  "",
                  "pm.test(\"Validate response body param : per_page\", function () {",
                  "    pm.expect(jsonData.per_page).to.eql(exp_per_page);",
                  "});",
                  "",
                  "pm.test(\"Validate response body param : total\", function () {",
                  "    pm.expect(jsonData.total).to.eql(exp_total);",
                  "});",
                  "",
                  "pm.test(\"Validate response body param : total_pages\", function () {",
                  "    pm.expect(jsonData.total_pages).to.eql(exp_total_pages);",
                  "});",
                  "",
                  "// Data array - id",
                  "var count = Object.keys(dataArray).length;",
                  "for (i = 0; i < count; i++) {",
                  "    var res_id = dataArray[i].id;",
                  "    var exp_id = exp_data_id_array[i];",
                  "    pm.test(\"Validate response body param : data array id at index \" + i, function () {",
                  "        pm.expect(res_id).to.eql(exp_id);",
                  "    });",
                  "}",
                  "",
                  "// Data array - name",
                  "for (i = 0; i < count; i++) {",
                  "    var res_name = dataArray[i].name;",
                  "    var exp_name = exp_data_name_array[i];",
                  "    pm.test(\"Validate response body param : data array name at index \" + i, function () {",
                  "        pm.expect(res_name).to.eql(exp_name);",
                  "    });",
                  "}",
                  "",
                  "// Data array - year",
                  "for (i = 0; i < count; i++) {",
                  "    var res_year = dataArray[i].year;",
                  "    var exp_year = exp_data_year_array[i];",
                  "    pm.test(\"Validate response body param : data array year at index \" + i, function () {",
                  "        pm.expect(res_year).to.eql(exp_year);",
                  "    });",
                  "}",
                  "",
                  "// Data array - color",
                  "for (i = 0; i < count; i++) {",
                  "    var res_color = dataArray[i].color;",
                  "    var exp_color = exp_data_color_array[i];",
                  "    pm.test(\"Validate response body param : data array color at index \" + i, function () {",
                  "        pm.expect(res_color).to.eql(exp_color);",
                  "    });",
                  "}",
                  "",
                  "// Data array - pantone_value",
                  "for (i = 0; i < count; i++) {",
                  "    var res_pantone = dataArray[i].pantone_value;",
                  "    var exp_pantone = exp_data_pantone_value_array[i];",
                  "    pm.test(\"Validate response body param : data array pantone_value at index \" + i, function () {",
                  "        pm.expect(res_pantone).to.eql(exp_pantone);",
                  "    });",
                  "}",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
