              "script": {
                "exec": [
                  "//Step 1 : Validate the status code ",
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "//Step 2 : Set the expected results",
                  "",
                  "var requestBody = pm.request.body.raw; ",
                  "requestBody = JSON.parse(requestBody)",
                  "var req_name=requestBody.name;",
                  "var req_job = requestBody.job;",
                  "var expected_Date = new Date().toISOString();",
                  "expected_Date = expected_Date.substring(0, 11);",
                  "console.log(expected_Date);",
                  "",
                  "//Step 3 : Validate Response Body",
                  "//Step 3.1 : Extract the response Body",
                  "var responseBody = pm.response.json();",
                  "",
                  "// Step 3.2 : Extract the response body parameters",
                  "",
                  "var res_name = responseBody.name;",
                  "var res_job = responseBody.job;",
                  "var res_id = responseBody.id;",
                  "var res_createdAt = responseBody.createdAt;",
                  "var res_meta_powered_by = responseBody._meta.powered_by;",
                  "var res_cta_label = responseBody._meta.cta.label;",
                  "",
                  "// Step 3.3 : Validate the response body parameters",
                  "",
                  "pm.test(\"Response body parameter : Name\", function () {",
                  "    pm.expect(res_name).to.eql(req_name);  ",
                  "})",
                  "",
                  "pm.test(\"Response body parameter : Job\", function () {",
                  "    pm.expect(res_job).to.eql(req_job);",
                  "})",
                  "",
                  "pm.test(\"Response body parameter : Id\", function () {",
                  "    pm.expect(res_id).length.greaterThan(0);",
                  "    pm.expect(parseInt(res_id)).to.not.null;",
                  "    pm.expect(parseInt(res_id)).to.greaterThan(0);",
                  "})",
                  "",
                  "pm.test(\"Response body parameter : Expected Date\", function () {",
                  "    pm.expect(res_createdAt.substring(0, 11)).to.eql(expected_Date);  ",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
