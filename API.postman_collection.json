    {
      "name": "Put_API",
      "item": [
        {
          "name": "New Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// =============================================",
                  "// EXPECTED VALUES",
                  "// =============================================",
                  "const EXP_STATUS_CODE       = 200;",
                  "const EXP_MAX_RESPONSE_TIME = 2000;",
                  "const EXP_NAME              = \"morpheus\";",
                  "const EXP_JOB               = \"leader\";",
                  "",
                  "// Parse response body once",
                  "const jsonData = pm.response.json();",
                  "",
                  "// =============================================",
                  "// SECTION 1 : STATUS CODE",
                  "// =============================================",
                  "pm.test(\"[PUT] Status code is 200\", () => {",
                  "    pm.response.to.have.status(EXP_STATUS_CODE);",
                  "});",
                  "",
                  "// =============================================",
                  "// SECTION 2 : RESPONSE TIME",
                  "// =============================================",
                  "pm.test(`[PUT] Response time is below ${EXP_MAX_RESPONSE_TIME}ms`, () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(EXP_MAX_RESPONSE_TIME);",
                  "});",
                  "",
                  "// =============================================",
                  "// SECTION 3 : RESPONSE BODY STRUCTURE",
                  "// =============================================",
                  "pm.test(\"[PUT] Response body has required keys with correct types\", () => {",
                  "    pm.expect(jsonData).to.be.an(\"object\");",
                  "    pm.expect(jsonData).to.have.property(\"name\").that.is.a(\"string\");",
                  "    pm.expect(jsonData).to.have.property(\"job\").that.is.a(\"string\");",
                  "    pm.expect(jsonData).to.have.property(\"updatedAt\").that.is.a(\"string\");",
                  "});",
                  "",
                  "// =============================================",
                  "// SECTION 4 : RESPONSE BODY PARAMETERS",
                  "// =============================================",
                  "pm.test(\"[PUT] Response body param: name matches expected value\", () => {",
                  "    pm.expect(jsonData.name).to.eql(EXP_NAME);",
                  "});",
                  "",
                  "pm.test(\"[PUT] Response body param: job matches expected value\", () => {",
                  "    pm.expect(jsonData.job).to.eql(EXP_JOB);",
                  "});",
                  "",
                  "pm.test(\"[PUT] Response body param: updatedAt is a non-empty valid ISO date\", () => {",
                  "    pm.expect(jsonData.updatedAt).to.not.be.empty;",
                  "    const date = new Date(jsonData.updatedAt);",
                  "    pm.expect(date.toISOString()).to.eql(jsonData.updatedAt);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
